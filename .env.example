# Copiez ce fichier en .env.local et remplissez les valeurs

# ── Supabase ────────────────────────────────────
# Obtenez ces valeurs sur https://supabase.com
# Projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ── OpenRouteService (optionnel) ────────────────
# Clé API configurée directement dans l'interface Paramètres
# Obtenez une clé gratuite sur https://openrouteservice.org
# NEXT_PUBLIC_ORS_API_KEY=your_key_here
