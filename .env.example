# ================================================
# VISITES PRO — Configuration environnement
# ================================================

# ── Supabase (publiques, nécessaires côté navigateur) ───────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ── OpenRouteService (SERVEUR UNIQUEMENT — jamais NEXT_PUBLIC_) ──
# Cette clé n'est JAMAIS exposée au navigateur. Elle est utilisée
# uniquement par les routes /api/route et /api/segment.
# Clé gratuite sur https://openrouteservice.org
ORS_API_KEY=5b3ce3597851110001cf6249...

# ── Google Places (optionnel, SERVEUR UNIQUEMENT) ──────────
# Laisser vide pour utiliser la recherche d'adresse gratuite
# (api-adresse.data.gouv.fr + Nominatim). Renseigner une clé
# active automatiquement Google Places Autocomplete à la place.
# GOOGLE_PLACES_API_KEY=
